rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.admin == true;
    }

    match /trees/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /areas/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Backward compatibility for legacy area collection.
    match /tagAreas/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rangers/{id} {
      allow read, write: if isAdmin();
    }

    match /users/{id} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{id} {
      allow read, write: if isAdmin();
    }
  }
}
